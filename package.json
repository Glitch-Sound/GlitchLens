{
  "name": "glitchlens",
  "displayName": "GlitchLens",
  "publisher": "glitch-sound",
  "description": "Instantly visualize TypeScript and JavaScript function flow as Mermaid sequence diagrams.",
  "license": "MIT",
  "version": "0.1.0",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Glitch-Sound/GlitchLens.git"
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "homepage": "https://github.com/Glitch-Sound/GlitchLens",
  "bugs": {
    "url": "https://github.com/Glitch-Sound/GlitchLens/issues"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "mermaid",
    "sequence-diagram",
    "sequence",
    "flow",
    "callgraph",
    "typescript",
    "javascript",
    "visualization",
    "ast",
    "codelens"
  ],
  "activationEvents": [
    "onCommand:glitchlens.visualizeFunctionFlow",
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:typescriptreact",
    "onLanguage:javascriptreact",
    "onLanguage:python"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "glitchlens.visualizeFunctionFlow",
        "title": "GlitchLens: Visualize Function Flow"
      }
    ],
    "configuration": {
      "title": "GlitchLens",
      "properties": {
        "glitchlens.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens actions for visualizing function flow."
        },
        "glitchlens.supportedLanguages": {
          "type": "array",
          "default": [
            "typescript",
            "javascript",
            "typescriptreact",
            "javascriptreact",
            "python"
          ],
          "items": {
            "type": "string"
          },
          "description": "Language identifiers supported by GlitchLens function flow analysis."
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "GlitchLens runs local static analysis only. In Restricted Mode, function flow commands, CodeLens, visualization, and Mermaid clipboard copy are disabled until the workspace is trusted."
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "test:unit": "npm run compile-tests && mocha --ui tdd \"out/test/**/*.test.js\" --ignore \"out/test/extension.test.js\"",
    "test:integration": "npm run compile-tests && npm run compile && npm run lint && vscode-test",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "@lezer/python": "^1.1.19",
    "mermaid": "^11.16.0"
  }
}
